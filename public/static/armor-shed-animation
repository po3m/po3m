anvas-overlay {\n  position: fixed;\n  top: 0; left: 0;\n  width: 100%; height: 100%;\n  pointer-events: none;\n  z-index: 999;\n}\n\n.page {\n  max-width: 660px;\n  margin: 0 auto;\n  padding: 80px 40px 160px;\n}\n\n.kicker {\n  font-size: 11px;\n  letter-spacing: 0.25em;\n  text-transform: uppercase;\n  color: #4a4540;\n  margin-bottom: 56px;\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n.kicker::after {\n  content: '';\n  flex: 1;\n  height: 1px;\n  background: linear-gradient(to right, #2a2520, transparent);\n}\n\n#editor {\n  font-size: 20px;\n  line-height: 2.05;\n  color: #e4ddd4;\n  outline: none;\n  white-space: pre-wrap;\n  word-break: break-word;\n  caret-color: #e4ddd4;\n  min-height: 500px;\n  position: relative;\n  z-index: 1;\n  text-wrap: pretty;\n}\n\n#editor:focus { outline: none; }\n\n/* Make first line (title) visually distinct */\n.poem-title-line {\n  display: block;\n  font-size: 28px;\n  font-weight: 600;\n  letter-spacing: 0.04em;\n  line-height: 1.4;\n  color: #f0ece4;\n  margin-bottom: 0.6em;\n}\n\n.legend {\n  margin-top: 56px;\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px 20px;\n}\n.legend-item {\n  font-size: 11px;\n  letter-spacing: 0.1em;\n  color: #3a3530;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n.legend-dot {\n  width: 6px; height: 6px;\n  border-radius: 50%;\n  flex-shrink: 0;\n}\n\n::-webkit-scrollbar { width: 4px; }\n::-webkit-scrollbar-track { background: transparent; }\n::-webkit-scrollbar-thumb { background: #2a2520; border-radius: 2px; }\n<\u002Fstyle>\n\n\n<\u002Fhead>\n<body>\n\n<canvas id=\"canvas-overlay\"><\u002Fcanvas>\n\n<div class=\"page\">\n  <div class=\"kicker\">Interactive Poem — certain words carry their own weather<\u002Fdiv>\n  <div id=\"editor\" contenteditable=\"true\" spellcheck=\"false\"><\u002Fdiv>\n  <div class=\"legend\">\n    <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#e06020\"><\u002Fdiv>fire · forge<\u002Fdiv>\n    <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#888\"><\u002Fdiv>smoke<\u002Fdiv>\n    <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#c8c8d8\"><\u002Fdiv>armor · metal · fortress · battlements · guard · vest<\u002Fdiv>\n    <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#4090d0\"><\u002Fdiv>waves · shore · rock · rocking<\u002Fdiv>\n    <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#a0bcd0\"><\u002Fdiv>wind<\u002Fdiv>\n    <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#d06080\"><\u002Fdiv>love<\u002Fdiv>\n    <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#504060\"><\u002Fdiv>fear<\u002Fdiv>\n    <div class=\"legend-item\"><div class=\"legend-dot\" style=\"background:#ffe080\"><\u002Fdiv>surrendered<\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<script>\n// ──────────────────────────────────────────────────────────────\n// POEM\n// ──────────────────────────────────────────────────────────────\nconst POEM = `The Armor Shed\n\nWhat would it take to lie like this again—\nA happy baby, rocking side to side,\nWith feet in hands and nothing to explain,\nNo fortress built, no battlements, no pride?\n\nThe armor that we forge from childhood's end\nGrows heavier with every passing year;\nWe learn to guard, to parry, to defend,\nUntil we can't recall what brought the fear.\n\nBut here you are: surrendered to the floor,\nThe ceiling holds no judgment, makes no demands,\nYou rock like waves against a patient shore,\nYour own two feet held gently in your hands.\n\nWith those we love, the armor finds its rest—\nFor love itself becomes the stronger vest.`;\n\n// ──────────────────────────────────────────────────────────────\n// WORD → EFFECT MAP\n// ──────────────────────────────────────────────────────────────\nconst WORD_EFFECTS = {\n  // Fire\n  fire: 'fire', flame: 'fire', flames: 'fire', burning: 'fire', blaze: 'fire',\n  forge: 'fire_sparks',\n  // Smoke\n  smoke: 'smoke', smoldering: 'smoke', haze: 'smoke', mist: 'smoke', fog: 'smoke',\n  // Metal / armor\n  armor: 'sparks', metal: 'sparks', steel: 'sparks', iron: 'sparks',\n  fortress: 'sparks', battlements: 'sparks', guard: 'sparks', vest: 'sparks',\n  shield: 'sparks', sword: 'sparks',\n  // Water\n  waves: 'water', wave: 'water', shore: 'water', ocean: 'water',\n  river: 'water', rain: 'water', rocking: 'water', rock: 'water',\n  // Wind\n  wind: 'wind', breeze: 'wind', gust: 'wind', drift: 'wind',\n  // Love / warmth\n  love: 'hearts',\n  // Fear / shadow\n  fear: 'shadow', darkness: 'shadow', dread: 'shadow',\n  heavier: 'gravity', heavy: 'gravity', weight: 'gravity',\n  // Peace / surrender\n  surrendered: 'glow', peace: 'glow', rest: 'glow', gentle: 'glow',\n};\n\n// ──────────────────────────────────────────────────────────────\n// CANVAS + RESIZE\n// ──────────────────────────────────────────────────────────────\nconst canvas = document.getElementById('canvas-overlay');\nconst ctx = canvas.getContext('2d');\nlet W, H;\n\nfunction resize() {\n  W = canvas.width = window.innerWidth;\n  H = canvas.height = window.innerHeight;\n}\nresize();\nwindow.addEventListener('resize', resize);\n\n// ──────────────────────────────────────────────────────────────\n// PARTICLE SYSTEM\n// ──────────────────────────────────────────────────────────────\nlet particles = [];\nlet emitters  = [];\n\nfunction spawnParticle(x, y, effect) {\n  const p = { x, y, age: 0, effect };\n\n  switch (effect) {\n    case 'fire':\n      p.vx = (Math.random() - 0.5) * 1.2;\n      p.vy = -(1.2 + Math.random() * 2.8);\n      p.life = 0.5 + Math.random() * 0.7;\n      p.r = 2 + Math.random() * 3.5;\n      p.hue = 10 + Math.random() * 35;\n      break;\n\n    case 'fire_sparks':\n      // Mix of fire particles + metal sparks\n      if (Math.random() < 0.6) {\n        p.sub = 'fire';\n        p.vx = (Math.random() - 0.5) * 1.5;\n        p.vy = -(1.0 + Math.random() * 2.5);\n        p.life = 0.4 + Math.random() * 0.6;\n        p.r = 1.5 + Math.random() * 3;\n        p.hue = 15 + Math.random() * 30;\n      } else {\n        p.sub = 'spark';\n        const a = Math.random() * Math.PI * 2;\n        const s = 1 + Math.random() * 3;\n        p.vx = Math.cos(a) * s;\n        p.vy = Math.sin(a) * s - 1;\n        p.life = 0.3 + Math.random() * 0.5;\n        p.r = 0.8 + Math.random() * 1.5;\n        p.g = 200 + Math.floor(Math.random() * 55);\n      }\n      break;\n\n    case 'smoke':\n      p.vx = (Math.random() - 0.5) * 0.5;\n      p.vy = -(0.25 + Math.random() * 0.5);\n      p.life = 2.5 + Math.random() * 2;\n      p.r = 7 + Math.random() * 12;\n      p.a = 0.08 + Math.random() * 0.1;\n      break;\n\n    case 'sparks': {\n      const a = Math.random() * Math.PI * 2;\n      const s = 0.4 + Math.random() * 2.5;\n      p.vx = Math.cos(a) * s;\n      p.vy = Math.sin(a) * s - 0.4;\n      p.gravity = 0.06;\n      p.life = 0.35 + Math.random() * 0.55;\n      p.r = 0.8 + Math.random() * 2;\n      p.g = 170 + Math.floor(Math.random() * 85);\n      break;\n    }\n\n    case 'water':\n      p.vx = (Math.random() - 0.5) * 1.2;\n      p.vy = -(0.15 + Math.random() * 0.6);\n      p.life = 1 + Math.random() * 1.5;\n      p.r = 1.5 + Math.random() * 3;\n      p.ph = Math.random() * Math.PI * 2;\n      break;\n\n    case 'wind':\n      p.vx = 1.8 + Math.random() * 3;\n      p.vy = (Math.random() - 0.5) * 0.5;\n      p.life = 0.6 + Math.random() * 0.8;\n      p.r = 0.8 + Math.random() * 1.5;\n      p.ph = Math.random() * Math.PI * 2;\n      p.len = 8 + Math.random() * 20;\n      break;\n\n    case 'hearts':\n      p.vx = (Math.random() - 0.5) * 0.7;\n      p.vy = -(0.4 + Math.random() * 1.2);\n      p.life = 1.5 + Math.random() * 1.2;\n      p.r = 4 + Math.random() * 6;\n      p.wobble = (Math.random() - 0.5) * 0.06;\n      break;\n\n    case 'shadow': {\n      const a = Math.random() * Math.PI * 2;\n      const s = 0.15 + Math.random() * 0.5;\n      p.vx = Math.cos(a) * s;\n      p.vy = Math.sin(a) * s;\n      p.life = 1.8 + Math.random() * 1.5;\n      p.r = 5 + Math.random() * 10;\n      break;\n    }\n\n    case 'gravity':\n      p.vx = (Math.random() - 0.5) * 1.2;\n      p.vy = -(0.5 + Math.random() * 1);\n      p.g = 0.07 + Math.random() * 0.05;\n      p.life = 1 + Math.random() * 0.8;\n      p.r = 1.5 + Math.random() * 2.5;\n      break;\n\n    case 'glow': {\n      const a = Math.random() * Math.PI * 2;\n      p.vx = Math.cos(a) * 0.3;\n      p.vy = Math.sin(a) * 0.3 - 0.25;\n      p.life = 2 + Math.random() * 1.5;\n      p.r = 2.5 + Math.random() * 5;\n      break;\n    }\n  }\n  particles.push(p);\n}\n\nconst DT = 1 / 60;\n\nfunction updateParticles() {\n  for (let i = particles.length - 1; i >= 0; i--) {\n    const p = particles[i];\n    p.age += DT;\n    if (p.age >= p.life) { particles.splice(i, 1); continue; }\n\n    switch (p.effect) {\n      case 'fire':\n        p.x += p.vx + Math.sin(p.age * 9) * 0.4;\n        p.y += p.vy;\n        p.vy *= 0.985;\n        break;\n      case 'fire_sparks':\n        if (p.sub === 'fire') {\n          p.x += p.vx + Math.sin(p.age * 8) * 0.3;\n          p.y += p.vy;\n        } else {\n          p.x += p.vx;\n          p.y += p.vy;\n          p.vx *= 0.95;\n          p.vy += 0.07;\n        }\n        break;\n      case 'smoke':\n        p.x += p.vx + Math.sin(p.age * 1.5) * 0.2;\n        p.y += p.vy;\n        p.r += 0.06;\n        break;\n      case 'sparks':\n        p.x += p.vx;\n        p.y += p.vy;\n        p.vx *= 0.95;\n        p.vy += p.gravity;\n        break;\n      case 'water':\n        p.x += p.vx + Math.sin(p.ph + p.age * 3) * 0.5;\n        p.y += p.vy;\n        break;\n      case 'wind':\n        p.x += p.vx;\n        p.y += p.vy + Math.sin(p.ph + p.age * 5) * 0.4;\n        break;\n      case 'hearts':\n        p.x += p.vx + Math.sin(p.age * 2.5) * 0.4;\n        p.y += p.vy;\n        p.vy *= 0.992;\n        break;\n      case 'shadow':\n        p.x += p.vx; p.vy *= 0.97; p.vx *= 0.97;\n        p.y += p.vy;\n        break;\n      case 'gravity':\n        p.x += p.vx;\n        p.vy += p.g;\n        p.y += p.vy;\n        break;\n      case 'glow':\n        p.x += p.vx; p.y += p.vy;\n        break;\n    }\n  }\n}\n\nfunction drawHeart(x, y, size, alpha) {\n  ctx.save();\n  ctx.globalAlpha = alpha;\n  ctx.fillStyle = `hsl(340, 75%, 65%)`;\n  ctx.translate(x, y);\n  ctx.beginPath();\n  const s = size;\n  ctx.moveTo(0, s * 0.25);\n  ctx.bezierCurveTo(-s, -s * 0.3,  -s * 1.1, s * 0.6,  0, s);\n  ctx.bezierCurveTo( s * 1.1, s * 0.6,  s, -s * 0.3,  0, s * 0.25);\n  ctx.closePath();\n  ctx.fill();\n  ctx.restore();\n}\n\nfunction drawParticles() {\n  ctx.clearRect(0, 0, W, H);\n\n  // ── draw word auras (background glows) ──────────────\n  for (const em of emitters) {\n    const rect = em.rect;\n    drawWordAura(rect, em.effect, performance.now() / 1000);\n  }\n\n  // ── draw particles ───────────────────────────────────\n  for (const p of particles) {\n    const t = p.age / p.life;\n    const ease = 1 - t;\n    ctx.save();\n\n    switch (p.effect) {\n      case 'fire': {\n        const a = ease * ease * 0.85;\n        ctx.globalAlpha = a;\n        // Core\n        ctx.fillStyle = `hsl(${p.hue + t * 20}, 100%, ${45 + t * 30}%)`;\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, p.r * ease, 0, Math.PI * 2);\n        ctx.fill();\n        // Glow\n        const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 4 * ease);\n        grd.addColorStop(0, `hsla(${p.hue}, 100%, 70%, ${a * 0.35})`);\n        grd.addColorStop(1, 'transparent');\n        ctx.fillStyle = grd;\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, p.r * 4 * ease, 0, Math.PI * 2);\n        ctx.fill();\n        break;\n      }\n      case 'fire_sparks': {\n        if (p.sub === 'fire') {\n          const a = ease * ease * 0.85;\n          ctx.globalAlpha = a;\n          ctx.fillStyle = `hsl(${p.hue + t * 15}, 100%, ${45 + t * 30}%)`;\n          ctx.beginPath();\n          ctx.arc(p.x, p.y, p.r * ease, 0, Math.PI * 2);\n          ctx.fill();\n        } else {\n          ctx.globalAlpha = ease;\n          const g = p.g;\n          ctx.fillStyle = `rgb(${g},${g},${g})`;\n          const ang = Math.atan2(p.vy, p.vx);\n          ctx.translate(p.x, p.y);\n          ctx.rotate(ang);\n          ctx.beginPath();\n          ctx.ellipse(0, 0, Math.max(p.r * 2.5, 1), Math.max(p.r * 0.5, 0.5), 0, 0, Math.PI * 2);\n          ctx.fill();\n        }\n        break;\n      }\n      case 'smoke': {\n        ctx.globalAlpha = p.a * ease * ease;\n        ctx.fillStyle = `hsl(0,0%,${35 + t * 35}%)`;\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);\n        ctx.fill();\n        break;\n      }\n      case 'sparks': {\n        ctx.globalAlpha = ease;\n        ctx.fillStyle = `rgb(${p.g},${p.g},${p.g})`;\n        const ang = Math.atan2(p.vy, p.vx);\n        ctx.translate(p.x, p.y);\n        ctx.rotate(ang);\n        ctx.beginPath();\n        ctx.ellipse(0, 0, Math.max(p.r * 2, 1), Math.max(p.r * 0.5, 0.5), 0, 0, Math.PI * 2);\n        ctx.fill();\n        break;\n      }\n      case 'water': {\n        const a = ease * 0.75;\n        ctx.globalAlpha = a;\n        const b = 150 + Math.floor(t * 60);\n        ctx.fillStyle = `rgba(60,140,${b},1)`;\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, p.r * ease, 0, Math.PI * 2);\n        ctx.fill();\n        // Ripple\n        if (t < 0.3) {\n          ctx.globalAlpha = (0.3 - t) / 0.3 * 0.4;\n          ctx.strokeStyle = `rgba(100,180,255,1)`;\n          ctx.lineWidth = 0.5;\n          ctx.beginPath();\n          ctx.arc(p.x, p.y, p.r * 3 * (t / 0.3), 0, Math.PI * 2);\n          ctx.stroke();\n        }\n        break;\n      }\n      case 'wind': {\n        ctx.globalAlpha = ease * 0.45;\n        ctx.strokeStyle = `rgba(180,210,230,1)`;\n        ctx.lineWidth = p.r;\n        ctx.lineCap = 'round';\n        ctx.beginPath();\n        ctx.moveTo(p.x - p.len * ease, p.y);\n        ctx.lineTo(p.x, p.y);\n        ctx.stroke();\n        break;\n      }\n      case 'hearts': {\n        const ha = t < 0.15 ? (t / 0.15) * 0.85 : ease * 0.85;\n        drawHeart(p.x, p.y - p.r, p.r * (0.4 + ease * 0.6), ha);\n        break;\n      }\n      case 'shadow': {\n        ctx.globalAlpha = ease * ease * 0.22;\n        const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r);\n        grd.addColorStop(0, 'rgba(15,8,25,1)');\n        grd.addColorStop(0.5, 'rgba(30,15,50,0.6)');\n        grd.addColorStop(1, 'transparent');\n        ctx.fillStyle = grd;\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);\n        ctx.fill();\n        break;\n      }\n      case 'gravity': {\n        ctx.globalAlpha = ease;\n        ctx.fillStyle = `rgba(170,155,135,1)`;\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, p.r * ease, 0, Math.PI * 2);\n        ctx.fill();\n        break;\n      }\n      case 'glow': {\n        ctx.globalAlpha = ease * ease * 0.65;\n        const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 2.5);\n        grd.addColorStop(0, 'rgba(255,240,180,1)');\n        grd.addColorStop(1, 'transparent');\n        ctx.fillStyle = grd;\n        ctx.beginPath();\n        ctx.arc(p.x, p.y, p.r * 2.5, 0, Math.PI * 2);\n        ctx.fill();\n        break;\n      }\n    }\n    ctx.restore();\n  }\n}\n\n// Word aura drawn behind particles as a persistent shimmer\nfunction drawWordAura(rect, effect, t) {\n  if (!rect) return;\n  const cx = rect.left + rect.width / 2;\n  const cy = rect.top + rect.height / 2;\n  const w = rect.width;\n  const h = rect.height;\n  const pulse = 0.5 + 0.5 * Math.sin(t * 2.5);\n\n  ctx.save();\n\n  switch (effect) {\n    case 'fire':\n    case 'fire_sparks': {\n      ctx.globalAlpha = 0.12 + pulse * 0.06;\n      const grd = ctx.createLinearGradient(cx, cy - h, cx, cy + h * 0.5);\n      grd.addColorStop(0, 'rgba(255,120,20,0)');\n      grd.addColorStop(0.5, 'rgba(255,80,0,0.9)');\n      grd.addColorStop(1, 'rgba(255,200,0,0.4)');\n      ctx.fillStyle = grd;\n      ctx.beginPath();\n      ctx.roundRect(rect.left - 4, rect.top - 4, w + 8, h + 8, 3);\n      ctx.fill();\n      break;\n    }\n    case 'sparks': {\n      ctx.globalAlpha = 0.08 + pulse * 0.05;\n      const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, Math.max(w, h));\n      grd.addColorStop(0, 'rgba(200,210,230,0.9)');\n      grd.addColorStop(1, 'transparent');\n      ctx.fillStyle = grd;\n      ctx.beginPath();\n      ctx.roundRect(rect.left - 6, rect.top - 4, w + 12, h + 8, 3);\n      ctx.fill();\n      break;\n    }\n    case 'smoke': {\n      ctx.globalAlpha = 0.07 + pulse * 0.04;\n      ctx.fillStyle = 'rgba(120,120,120,0.6)';\n      ctx.beginPath();\n      ctx.roundRect(rect.left - 3, rect.top - 3, w + 6, h + 6, 3);\n      ctx.fill();\n      break;\n    }\n    case 'water': {\n      ctx.globalAlpha = 0.12 + pulse * 0.06;\n      const grd = ctx.createLinearGradient(rect.left, cy, rect.right, cy);\n      grd.addColorStop(0, 'transparent');\n      grd.addColorStop(0.5, 'rgba(50,140,220,0.8)');\n      grd.addColorStop(1, 'transparent');\n      ctx.fillStyle = grd;\n      ctx.beginPath();\n      ctx.roundRect(rect.left - 2, rect.top - 2, w + 4, h + 4, 3);\n      ctx.fill();\n      break;\n    }\n    case 'wind': {\n      ctx.globalAlpha = 0.06 + pulse * 0.03;\n      ctx.fillStyle = 'rgba(180,215,240,0.7)';\n      ctx.beginPath();\n      ctx.roundRect(rect.left - 2, rect.top - 2, w + 4, h + 4, 3);\n      ctx.fill();\n      break;\n    }\n    case 'hearts': {\n      ctx.globalAlpha = 0.1 + pulse * 0.06;\n      const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, Math.max(w, h) * 0.8);\n      grd.addColorStop(0, 'rgba(230,80,130,0.9)');\n      grd.addColorStop(1, 'transparent');\n      ctx.fillStyle = grd;\n      ctx.beginPath();\n      ctx.roundRect(rect.left - 4, rect.top - 4, w + 8, h + 8, 4);\n      ctx.fill();\n      break;\n    }\n    case 'shadow': {\n      ctx.globalAlpha = 0.12 + pulse * 0.05;\n      const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, Math.max(w, h));\n      grd.addColorStop(0, 'rgba(15,8,30,0.9)');\n      grd.addColorStop(1, 'transparent');\n      ctx.fillStyle = grd;\n      ctx.beginPath();\n      ctx.roundRect(rect.left - 8, rect.top - 4, w + 16, h + 8, 4);\n      ctx.fill();\n      break;\n    }\n    case 'gravity': {\n      ctx.globalAlpha = 0.07 + pulse * 0.04;\n      ctx.fillStyle = 'rgba(160,145,120,0.7)';\n      ctx.beginPath();\n      ctx.roundRect(rect.left - 2, rect.top - 2, w + 4, h + 4, 3);\n      ctx.fill();\n      break;\n    }\n    case 'glow': {\n      ctx.globalAlpha = 0.1 + pulse * 0.07;\n      const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, Math.max(w, h));\n      grd.addColorStop(0, 'rgba(255,240,160,0.9)');\n      grd.addColorStop(1, 'transparent');\n      ctx.fillStyle = grd;\n      ctx.beginPath();\n      ctx.roundRect(rect.left - 6, rect.top - 4, w + 12, h + 8, 4);\n      ctx.fill();\n      break;\n    }\n  }\n  ctx.restore();\n}\n\n// ──────────────────────────────────────────────────────────────\n// WORD SCANNING (no DOM mutation)\n// ──────────────────────────────────────────────────────────────\nfunction findWordRects(word) {\n  const editor = document.getElementById('editor');\n  const rects = [];\n  const walker = document.createTreeWalker(editor, NodeFilter.SHOW_TEXT);\n  const re = new RegExp(`\\\\b${word}\\\\b`, 'gi');\n\n  while (walker.nextNode()) {\n    const node = walker.currentNode;\n    let m;\n    while ((m = re.exec(node.textContent)) !== null) {\n      const range = document.createRange();\n      range.setStart(node, m.index);\n      range.setEnd(node, m.index + m[0].length);\n      for (const r of range.getClientRects()) {\n        rects.push(r);\n      }\n    }\n  }\n  return rects;\n}\n\nfunction scanWords() {\n  emitters = [];\n  for (const [word, effect] of Object.entries(WORD_EFFECTS)) {\n    const rects = findWordRects(word);\n    for (const rect of rects) {\n      emitters.push({ word, effect, rect, timer: Math.random() });\n    }\n  }\n}\n\n// ──────────────────────────────────────────────────────────────\n// SPAWN RATES\n// ──────────────────────────────────────────────────────────────\nconst SPAWN_RATE = {\n  fire: 10, fire_sparks: 7, smoke: 1.5, sparks: 4,\n  water: 3.5, wind: 7, hearts: 1.2, shadow: 2, gravity: 2.5, glow: 2,\n};\n\n// ──────────────────────────────────────────────────────────────\n// MAIN LOOP\n// ──────────────────────────────────────────────────────────────\nlet lastScan = 0;\nconst MAX_PARTICLES = 1800;\n\nfunction loop(ts) {\n  requestAnimationFrame(loop);\n\n  if (ts - lastScan > 350) {\n    scanWords();\n    lastScan = ts;\n  }\n\n  for (const em of emitters) {\n    const rate = SPAWN_RATE[em.effect] || 2;\n    em.timer += DT;\n    while (em.timer > 1 / rate) {\n      em.timer -= 1 / rate;\n      if (particles.length < MAX_PARTICLES) {\n        const rect = em.rect;\n        // Spawn positions vary by effect\n        let x = rect.left + Math.random() * rect.width;\n        let y;\n        if (['fire', 'fire_sparks', 'smoke', 'hearts', 'glow'].includes(em.effect)) {\n          y = rect.top + rect.height * (0.3 + Math.random() * 0.7);\n        } else if (em.effect === 'wind') {\n          x = rect.left - 5;\n          y = rect.top + rect.height * Math.random();\n        } else {\n          y = rect.top + rect.height * Math.random();\n        }\n        spawnParticle(x, y, em.effect);\n      }\n    }\n  }\n\n  updateParticles();\n  drawParticles();\n}\n\n// ──────────────────────────────────────────────────────────────\n// INIT\n// ──────────────────────────────────────────────────────────────\nconst editor = document.getElementById('editor');\neditor.textContent = POEM;\n\n// Re-scan on input (debounced)\nlet inputTimer;\neditor.addEventListener('input', () => {\n  clearTimeout(inputTimer);\n  inputTimer = setTimeout(scanWords, 300);\n});\n\n// Kick off\nscanWords();\nrequestAnimationFrame(loop);\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
